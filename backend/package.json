    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.13",
    "@types/luxon": "^3.4.2",
    "@types/multer": "^1.4.12",
