    "@nestjs/platform-socket.io": "^10.4.1",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/websockets": "^10.4.1",
    "@prisma/client": "^5.19.1",
    "baileys": "^6.7.22",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.15.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
