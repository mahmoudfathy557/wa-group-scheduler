# Postgres
DATABASE_URL=******localhost:5432/wa_scheduler

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=<paste base64 from openssl rand -base64 48>
JWT_EXPIRES_IN=12h

# Encryption (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=<paste hex from openssl rand -hex 32>

# App
PORT=3000
CLIENT_URL=http://localhost:5173

# Sending policy
DAILY_MESSAGE_CAP_PER_TENANT=100
MESSAGE_DELAY_MIN_MS=5000
MESSAGE_DELAY_MAX_MS=10000
LOG_RETENTION_DAYS=7

# Cloudinary (for schedule image attachments)
CLOUDINARY_CLOUD_NAME=<your cloud name>
CLOUDINARY_API_KEY=<your api key>
CLOUDINARY_API_SECRET=<your api secret>
CLOUDINARY_FOLDER=wa-scheduler

# Frontend (Vite)
VITE_API_URL=http://localhost:3000
